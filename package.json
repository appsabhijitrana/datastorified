{
  "name": "datastorified",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter './apps/*' dev",
    "build": "corepack pnpm db:generate && corepack pnpm --parallel --filter './apps/*' build",
    "lint": "eslint apps packages --ext .ts,.tsx --max-warnings 0",
    "typecheck": "corepack pnpm --parallel --filter './apps/*' typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "corepack pnpm --filter @datastorified/database db:generate",
    "db:push": "corepack pnpm --filter @datastorified/database db:push",
    "db:studio": "corepack pnpm --filter @datastorified/database db:studio",
    "ci": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test:coverage && corepack pnpm build",
    "turbo:build": "turbo build",
    "dev:website": "pnpm --filter @datastorified/website dev",
    "dev:calculators": "pnpm --filter @datastorified/calculators dev",
    "dev:tools": "pnpm --filter @datastorified/tools dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.17",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.19",
    "fast-check": "^4.2.0",
    "jsdom": "^26.1.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
