{
  "name": "datastorified",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter './apps/*' dev",
    "build": "corepack pnpm --parallel --filter './apps/*' build",
    "lint": "corepack pnpm --parallel --filter './apps/*' typecheck",
    "typecheck": "corepack pnpm --parallel --filter './apps/*' typecheck",
    "turbo:build": "turbo build",
    "dev:website": "pnpm --filter @datastorified/website dev",
    "dev:calculators": "pnpm --filter @datastorified/calculators dev",
    "dev:tools": "pnpm --filter @datastorified/tools dev"
  },
  "devDependencies": { "@types/lodash": "^4.17.17", "@types/react": "19.2.17", "@types/react-dom": "19.2.3", "turbo": "^2.3.3", "typescript": "^5.7.2" },
  "pnpm": { "overrides": { "react": "19.0.0", "react-dom": "19.0.0", "@types/react": "19.2.17", "@types/react-dom": "19.2.3" } }
}
